{
  "name": "@dev-herald/health",
  "version": "1.4.0",
  "description": "GitHub Action: Knip JSON → Dev Herald health ingest API",
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "turbo run build",
    "package": "pnpm run typecheck && ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test:prep": "turbo run test:prep --filter=./apps/*",
    "test": "pnpm run test:prep && vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "github-action",
    "knip",
    "dev-herald",
    "health"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vercel/ncc": "^0.38.1",
    "turbo": "^2.5.4",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
